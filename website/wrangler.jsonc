{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wb-sneat-dev",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "wb.sneat.dev", "custom_domain": true }
  ]
}

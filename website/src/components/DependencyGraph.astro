---
type Status = 'current' | 'behind' | 'blocked' | 'selected';

interface GraphNode {
  id: string;
  x: number;
  y: number;
  w: number;
  h: number;
  org: 'dal-go' | 'sneat-co';
  repo: string;
  module: string;
  version: string;
  status: Status;
  manifest: string;
  relation: string;
  consumers: number;
  upstream: string[];
  downstream: string[];
}

interface GraphEdge {
  from: string;
  to: string;
  indirect?: boolean;
  primary?: boolean;
}

const W = 1040;
const H = 580;
const nodeW = 174;
const nodeH = 72;

const nodes: GraphNode[] = [
  {
    id: 'record', x: 22, y: 236, w: nodeW, h: nodeH, org: 'dal-go', repo: 'dal-go/record',
    module: 'github.com/dal-go/record', version: 'v0.1.0', status: 'selected', manifest: 'go.mod',
    relation: 'selected provider', consumers: 7, upstream: [],
    downstream: ['dalgo', 'firestore', 'datastore', 'sql', 'facade', 'api', 'bots'],
  },
  {
    id: 'dalgo', x: 228, y: 236, w: nodeW, h: nodeH, org: 'dal-go', repo: 'dal-go/dalgo',
    module: 'github.com/dal-go/dalgo', version: 'v0.63.1', status: 'behind', manifest: 'go.mod',
    relation: 'direct consumer · provider', consumers: 6, upstream: ['record'],
    downstream: ['firestore', 'datastore', 'sql', 'facade', 'api', 'bots'],
  },
  {
    id: 'firestore', x: 434, y: 94, w: nodeW, h: nodeH, org: 'dal-go', repo: 'dal-go/dalgo2firestore',
    module: 'github.com/dal-go/dalgo2firestore', version: 'v0.16.3', status: 'current', manifest: 'go.mod',
    relation: 'direct consumer · adapter', consumers: 3, upstream: ['record', 'dalgo'],
    downstream: ['facade', 'api', 'bots'],
  },
  {
    id: 'datastore', x: 434, y: 236, w: nodeW, h: nodeH, org: 'dal-go', repo: 'dal-go/dalgo2datastore',
    module: 'github.com/dal-go/dalgo2datastore', version: 'v0.9.2', status: 'behind', manifest: 'go.mod',
    relation: 'direct consumer · adapter', consumers: 3, upstream: ['record', 'dalgo'],
    downstream: ['facade', 'api', 'bots'],
  },
  {
    id: 'sql', x: 434, y: 378, w: nodeW, h: nodeH, org: 'dal-go', repo: 'dal-go/dalgo2sql',
    module: 'github.com/dal-go/dalgo2sql', version: 'v0.8.4', status: 'blocked', manifest: 'go.mod',
    relation: 'direct consumer · adapter', consumers: 3, upstream: ['record', 'dalgo'],
    downstream: ['facade', 'api', 'bots'],
  },
  {
    id: 'facade', x: 640, y: 236, w: nodeW, h: nodeH, org: 'sneat-co', repo: 'sneat-co/facade',
    module: 'github.com/sneat-co/facade', version: 'v0.12.0', status: 'behind', manifest: 'go.mod',
    relation: 'direct consumer · provider', consumers: 2,
    upstream: ['record', 'dalgo', 'firestore', 'datastore', 'sql'], downstream: ['api', 'bots'],
  },
  {
    id: 'api', x: 846, y: 164, w: nodeW, h: nodeH, org: 'sneat-co', repo: 'sneat-co/sneat-api',
    module: 'github.com/sneat-co/sneat-api', version: 'v0.31.0', status: 'blocked', manifest: 'go.mod',
    relation: 'direct consumer · application', consumers: 0,
    upstream: ['record', 'dalgo', 'firestore', 'datastore', 'sql', 'facade'], downstream: [],
  },
  {
    id: 'bots', x: 846, y: 308, w: nodeW, h: nodeH, org: 'sneat-co', repo: 'sneat-co/sneat-bots',
    module: 'github.com/sneat-co/sneat-bots', version: 'v0.19.0', status: 'behind', manifest: 'go.mod',
    relation: 'direct consumer · application', consumers: 0,
    upstream: ['record', 'dalgo', 'firestore', 'datastore', 'sql', 'facade'], downstream: [],
  },
];

const edges: GraphEdge[] = [
  { from: 'record', to: 'dalgo', primary: true },
  { from: 'dalgo', to: 'firestore', primary: true },
  { from: 'dalgo', to: 'datastore' },
  { from: 'dalgo', to: 'sql' },
  { from: 'firestore', to: 'facade', primary: true },
  { from: 'datastore', to: 'facade' },
  { from: 'sql', to: 'facade' },
  { from: 'facade', to: 'api', primary: true },
  { from: 'facade', to: 'bots' },
  { from: 'record', to: 'facade', indirect: true },
  { from: 'dalgo', to: 'api', indirect: true },
];

const byId = new Map(nodes.map((node) => [node.id, node]));
const edgePath = (edge: GraphEdge) => {
  const from = byId.get(edge.from)!;
  const to = byId.get(edge.to)!;
  const x1 = from.x + from.w;
  const y1 = from.y + from.h / 2;
  const x2 = to.x;
  const y2 = to.y + to.h / 2;
  const bend = Math.max(12, (x2 - x1) * 0.5);
  if (edge.indirect) {
    const lift = edge.from === 'record' ? -176 : 154;
    return `M ${x1} ${y1} C ${x1 + bend * 0.45} ${y1 + lift}, ${x2 - bend * 0.45} ${y2 + lift}, ${x2} ${y2}`;
  }
  return `M ${x1} ${y1} C ${x1 + bend} ${y1}, ${x2 - bend} ${y2}, ${x2} ${y2}`;
};

const statusLabel: Record<Status, string> = {
  current: 'current',
  behind: 'behind',
  blocked: 'blocked',
  selected: 'selected release',
};

const shortModule = (module: string) => module.replace('github.com/', '');
---

<section class="dependency-feature section" id="deps-graph" data-dependency-graph>
  <div class="container">
    <header class="dependency-heading" data-reveal>
      <div>
        <p class="eyebrow">Coming soon · <code>wb deps graph</code></p>
        <h2>Understand the dependency fleet.</h2>
      </div>
      <div class="dependency-heading-copy">
        <p class="lead">See the blast radius before changing a dependency.</p>
        <p>
          Discover relationships across selected repositories, expose version drift,
          and see the provider-first release order before a worktree is created.
        </p>
      </div>
    </header>

    <div class="graph-browser" data-reveal>
      <div class="graph-toolbar" aria-label="Dependency graph controls">
        <div class="graph-tabs" role="tablist" aria-label="Graph projection">
          <button type="button" role="tab" aria-selected="true" data-projection="repos">Repositories</button>
          <button type="button" role="tab" aria-selected="false" data-projection="dependencies">Dependencies</button>
          <button type="button" role="tab" aria-selected="false" data-projection="versions">Versions</button>
        </div>
        <label class="graph-search">
          <span class="sr-only">Search repositories and modules</span>
          <input type="search" placeholder="Search graph…" data-graph-search />
          <kbd>/</kbd>
        </label>
        <label class="graph-org">
          <span class="sr-only">Filter by GitHub organisation</span>
          <select data-graph-org>
            <option value="all">All organisations</option>
            <option value="dal-go">dal-go</option>
            <option value="sneat-co">sneat-co</option>
          </select>
        </label>
        <button class="outdated-toggle" type="button" aria-pressed="false" data-highlight-outdated>
          <span aria-hidden="true"></span> Highlight outdated
        </button>
      </div>

      <div class="graph-workspace">
        <div class="graph-canvas">
          <div class="graph-canvas-head">
            <div>
              <b>github.com</b>
              <span>provider-first release topology</span>
            </div>
            <div class="graph-zoom" aria-label="Graph zoom controls">
              <button type="button" data-zoom="in" aria-label="Zoom in">+</button>
              <button type="button" data-zoom="out" aria-label="Zoom out">−</button>
              <button type="button" data-zoom="fit">Fit</button>
              <button type="button" data-zoom="reset">Reset</button>
            </div>
          </div>

          <div class="graph-stage">
            <svg
              data-graph-svg
              viewBox={`0 0 ${W} ${H}`}
              xmlns="http://www.w3.org/2000/svg"
              role="img"
              aria-labelledby="dependency-graph-title dependency-graph-desc"
            >
              <title id="dependency-graph-title">Example WB repository dependency graph</title>
              <desc id="dependency-graph-desc">
                Provider repositories are arranged left to right in release waves. The highlighted path runs from record through DALgo and the Firestore adapter to facade and the API.
              </desc>
              <defs>
                <marker id="graph-arrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="strokeWidth">
                  <path d="M 0 0 L 8 4 L 0 8 z" />
                </marker>
                <marker id="graph-arrow-active" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="strokeWidth">
                  <path d="M 0 0 L 8 4 L 0 8 z" />
                </marker>
              </defs>

              <g data-graph-viewport>
                <rect class="org-zone" x="8" y="42" width="612" height="500" rx="18" />
                <rect class="org-zone org-zone-sneat" x="626" y="42" width="406" height="500" rx="18" />
                <text class="org-label" x="24" y="68">github.com/dal-go</text>
                <text class="org-label" x="642" y="68">github.com/sneat-co</text>

                {[
                  ['provider', 109], ['core', 315], ['adapter wave', 521], ['facade', 727], ['applications', 933],
                ].map(([label, x], index) => (
                  <g class="wave-guide" aria-hidden="true">
                    <line x1={x} y1="78" x2={x} y2="522" />
                    <text x={x} y="564" text-anchor="middle">0{index} · {String(label).toUpperCase()}</text>
                  </g>
                ))}

                <g class="graph-edges" aria-hidden="true">
                  {edges.map((edge) => (
                    <path
                      d={edgePath(edge)}
                      class:list={['graph-edge', { 'is-indirect': edge.indirect, 'is-primary': edge.primary }]}
                      data-from={edge.from}
                      data-to={edge.to}
                      marker-end={edge.primary ? 'url(#graph-arrow-active)' : 'url(#graph-arrow)'}
                    />
                  ))}
                </g>

                <g class="graph-nodes">
                  {nodes.map((node) => (
                    <a
                      href="#dependency-details"
                      class:list={['graph-node', `status-${node.status}`, { 'is-primary': ['record', 'dalgo', 'firestore', 'facade', 'api'].includes(node.id) }]}
                      data-graph-node
                      data-id={node.id}
                      data-org={node.org}
                      data-repo={node.repo}
                      data-module={node.module}
                      data-version={node.version}
                      data-status={statusLabel[node.status]}
                      data-manifest={node.manifest}
                      data-relation={node.relation}
                      data-consumers={String(node.consumers)}
                      data-upstream={node.upstream.join(',')}
                      data-downstream={node.downstream.join(',')}
                      data-main-repos={node.repo}
                      data-sub-repos={`${node.version} · ${statusLabel[node.status]}`}
                      data-main-dependencies={shortModule(node.module)}
                      data-sub-dependencies={`${node.consumers} downstream consumer${node.consumers === 1 ? '' : 's'}`}
                      data-main-versions={`${node.repo.split('/').at(-1)}@${node.version}`}
                      data-sub-versions={`${node.manifest} · ${statusLabel[node.status]}`}
                      aria-label={`${node.repo}, ${node.module} at ${node.version}, ${statusLabel[node.status]}, ${node.consumers} downstream consumers`}
                    >
                      <g>
                        <rect class="node-card" x={node.x} y={node.y} width={node.w} height={node.h} rx="12" />
                        <rect class="node-accent" x={node.x} y={node.y} width="5" height={node.h} rx="2.5" />
                        <circle class="node-status" cx={node.x + 18} cy={node.y + 19} r="4" />
                        <text class="node-main" x={node.x + 29} y={node.y + 23} data-node-main>{node.repo}</text>
                        <text class="node-sub" x={node.x + 16} y={node.y + 46} data-node-sub>{node.version} · {statusLabel[node.status]}</text>
                        <text class="node-meta" x={node.x + 16} y={node.y + 62}>{node.manifest}</text>
                        <path class="node-chevron" d={`M ${node.x + node.w - 18} ${node.y + 32} l 5 4 l -5 4`} />
                      </g>
                    </a>
                  ))}
                </g>
              </g>
            </svg>
          </div>

          <div class="graph-mobile" aria-label="Simplified dependency release order">
            <ol>
              <li class="status-selected"><b>dal-go/record</b><span>v0.1.0 · selected provider</span></li>
              <li class="status-behind"><b>dal-go/dalgo</b><span>v0.63.1 · behind</span></li>
              <li class="mobile-branch">
                <span><b>dalgo2firestore</b><small>current</small></span>
                <span><b>dalgo2datastore</b><small>behind</small></span>
                <span><b>dalgo2sql</b><small>blocked</small></span>
              </li>
              <li class="status-behind"><b>sneat-co/facade</b><span>v0.12.0 · behind</span></li>
              <li class="mobile-branch">
                <span><b>sneat-api</b><small>blocked</small></span>
                <span><b>sneat-bots</b><small>behind</small></span>
              </li>
            </ol>
          </div>

          <div class="graph-legend" aria-label="Dependency graph legend">
            <span><i class="legend-line"></i> direct</span>
            <span><i class="legend-line is-dashed"></i> indirect</span>
            <span><i class="legend-dot is-current"></i> current</span>
            <span><i class="legend-dot is-behind"></i> behind</span>
            <span><i class="legend-dot is-blocked"></i> blocked</span>
            <span><i class="legend-dot is-selected"></i> selected release</span>
          </div>
        </div>

        <aside class="graph-inspector" aria-label="Graph command and selected dependency details">
          <div class="graph-command-card">
            <div class="graph-command-label"><span>Command</span><b>planned</b></div>
            <code><span>$</span> <span data-graph-command>wb deps graph --fleet --view repos --open</span></code>
            <button type="button" class="copy-btn" data-copy="wb deps graph --fleet --view repos --open" data-graph-copy>Copy</button>
          </div>
          <dl class="graph-results" aria-label="Representative graph results">
            <div><dt>34</dt><dd>repositories</dd></div>
            <div><dt>19</dt><dd>modules</dd></div>
            <div><dt>61</dt><dd>dependency edges</dd></div>
            <div class="result-warning"><dt>4</dt><dd>outdated selections</dd></div>
            <div class="result-danger"><dt>2</dt><dd>blocked release paths</dd></div>
          </dl>
          <div class="graph-details" id="dependency-details" aria-live="polite">
            <p class="graph-detail-label">Selected node</p>
            <h3 data-detail-repo>dal-go/record</h3>
            <dl>
              <div><dt>Module</dt><dd data-detail-module>github.com/dal-go/record</dd></div>
              <div><dt>Version</dt><dd data-detail-version>v0.1.0</dd></div>
              <div><dt>Manifest</dt><dd data-detail-manifest>go.mod</dd></div>
              <div><dt>Relationship</dt><dd data-detail-relation>selected provider</dd></div>
              <div><dt>Downstream</dt><dd data-detail-consumers>7 consumers</dd></div>
            </dl>
            <p>Focus a card for details. Select it to trace its complete upstream and downstream path.</p>
          </div>
        </aside>
      </div>

      <div class="dependency-table-wrap">
        <table>
          <caption>Accessible dependency order for the example fleet</caption>
          <thead><tr><th>Wave</th><th>Repository</th><th>Selected version</th><th>Status</th></tr></thead>
          <tbody>
            {nodes.map((node, index) => (
              <tr><td>{index < 2 ? index : index < 5 ? 2 : index === 5 ? 3 : 4}</td><th scope="row">{node.repo}</th><td>{node.version}</td><td>{statusLabel[node.status]}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="projection-notes" data-reveal>
      <article><span>01</span><h3>Repositories</h3><p>Repository → repository. Read release order, propagation waves, and downstream blockers.</p></article>
      <article><span>02</span><h3>Dependencies</h3><p>Module → consumer. Ask which repositories are affected before a provider changes.</p></article>
      <article><span>03</span><h3>Versions</h3><p>Dependency@version → repository. Make old, current, and conflicting selections visible.</p></article>
    </div>
  </div>
</section>

<script>
  const graphRoot = document.querySelector<HTMLElement>('[data-dependency-graph]');

  if (graphRoot) {
    const graphNodes = Array.from(graphRoot.querySelectorAll<SVGAElement>('[data-graph-node]'));
    const graphEdges = Array.from(graphRoot.querySelectorAll<SVGPathElement>('.graph-edge'));
    const tabs = Array.from(graphRoot.querySelectorAll<HTMLButtonElement>('[data-projection]'));
    const search = graphRoot.querySelector<HTMLInputElement>('[data-graph-search]');
    const org = graphRoot.querySelector<HTMLSelectElement>('[data-graph-org]');
    const outdated = graphRoot.querySelector<HTMLButtonElement>('[data-highlight-outdated]');
    const svg = graphRoot.querySelector<SVGSVGElement>('[data-graph-svg]');
    const command = graphRoot.querySelector<HTMLElement>('[data-graph-command]');
    const copy = graphRoot.querySelector<HTMLButtonElement>('[data-graph-copy]');
    let selectedId = 'record';
    let projection = 'repos';

    const commands: Record<string, string> = {
      repos: 'wb deps graph --fleet --view repos --open',
      dependencies: "wb deps graph --fleet --view dependencies --match 'dal-go/*' --open",
      versions: 'wb deps graph --fleet --view selections --dependency github.com/dal-go/dalgo --open',
    };

    const details = {
      repo: graphRoot.querySelector<HTMLElement>('[data-detail-repo]'),
      module: graphRoot.querySelector<HTMLElement>('[data-detail-module]'),
      version: graphRoot.querySelector<HTMLElement>('[data-detail-version]'),
      manifest: graphRoot.querySelector<HTMLElement>('[data-detail-manifest]'),
      relation: graphRoot.querySelector<HTMLElement>('[data-detail-relation]'),
      consumers: graphRoot.querySelector<HTMLElement>('[data-detail-consumers]'),
    };

    const showDetails = (node: SVGAElement) => {
      if (details.repo) details.repo.textContent = node.dataset.repo ?? '';
      if (details.module) details.module.textContent = node.dataset.module ?? '';
      if (details.version) details.version.textContent = node.dataset.version ?? '';
      if (details.manifest) details.manifest.textContent = node.dataset.manifest ?? '';
      if (details.relation) details.relation.textContent = node.dataset.relation ?? '';
      if (details.consumers) {
        const count = Number(node.dataset.consumers ?? 0);
        details.consumers.textContent = `${count} consumer${count === 1 ? '' : 's'}`;
      }
    };

    const selectNode = (node: SVGAElement) => {
      selectedId = node.dataset.id ?? '';
      const related = new Set([
        selectedId,
        ...(node.dataset.upstream ?? '').split(',').filter(Boolean),
        ...(node.dataset.downstream ?? '').split(',').filter(Boolean),
      ]);
      graphRoot.classList.add('has-node-selection');
      graphNodes.forEach((candidate) => {
        const id = candidate.dataset.id ?? '';
        candidate.classList.toggle('is-selected-node', id === selectedId);
        candidate.classList.toggle('is-related', related.has(id));
        candidate.classList.toggle('is-dimmed', !related.has(id));
      });
      graphEdges.forEach((edge) => {
        const active = related.has(edge.dataset.from ?? '') && related.has(edge.dataset.to ?? '');
        edge.classList.toggle('is-path', active);
        edge.classList.toggle('is-dimmed', !active);
      });
      showDetails(node);
    };

    const applyProjection = (next: string) => {
      projection = next;
      graphRoot.dataset.projection = projection;
      tabs.forEach((tab) => tab.setAttribute('aria-selected', String(tab.dataset.projection === projection)));
      graphNodes.forEach((node) => {
        const main = node.querySelector<SVGTextElement>('[data-node-main]');
        const sub = node.querySelector<SVGTextElement>('[data-node-sub]');
        const key = projection === 'dependencies' ? 'Dependencies' : projection === 'versions' ? 'Versions' : 'Repos';
        if (main) main.textContent = node.dataset[`main${key}`] ?? '';
        if (sub) sub.textContent = node.dataset[`sub${key}`] ?? '';
      });
      const value = commands[projection];
      if (command) command.textContent = value;
      if (copy) copy.dataset.copy = value;
    };

    const applyFilters = () => {
      const query = (search?.value ?? '').trim().toLowerCase();
      const selectedOrg = org?.value ?? 'all';
      graphNodes.forEach((node) => {
        const haystack = `${node.dataset.repo} ${node.dataset.module} ${node.dataset.version}`.toLowerCase();
        const match = (!query || haystack.includes(query)) && (selectedOrg === 'all' || node.dataset.org === selectedOrg);
        node.classList.toggle('is-filtered', !match);
      });
    };

    tabs.forEach((tab) => tab.addEventListener('click', () => applyProjection(tab.dataset.projection ?? 'repos')));
    search?.addEventListener('input', applyFilters);
    org?.addEventListener('change', applyFilters);
    outdated?.addEventListener('click', () => {
      const pressed = outdated.getAttribute('aria-pressed') !== 'true';
      outdated.setAttribute('aria-pressed', String(pressed));
      graphRoot.classList.toggle('highlight-outdated', pressed);
    });

    graphNodes.forEach((node) => {
      node.addEventListener('mouseenter', () => showDetails(node));
      node.addEventListener('focus', () => showDetails(node));
      node.addEventListener('mouseleave', () => {
        const selected = graphNodes.find((candidate) => candidate.dataset.id === selectedId);
        if (selected) showDetails(selected);
      });
      node.addEventListener('click', (event) => {
        event.preventDefault();
        selectNode(node);
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== search) {
        event.preventDefault();
        search?.focus();
      }
    });

    if (svg) {
      const initial = { x: 0, y: 0, width: 1040, height: 580 };
      let view = { ...initial };
      let pointer: { id: number; x: number; y: number } | undefined;
      const updateView = () => svg.setAttribute('viewBox', `${view.x} ${view.y} ${view.width} ${view.height}`);
      const zoomBy = (factor: number) => {
        const nextWidth = Math.min(1450, Math.max(500, view.width * factor));
        const nextHeight = nextWidth * (initial.height / initial.width);
        view.x += (view.width - nextWidth) / 2;
        view.y += (view.height - nextHeight) / 2;
        view.width = nextWidth;
        view.height = nextHeight;
        updateView();
      };
      graphRoot.querySelector('[data-zoom="in"]')?.addEventListener('click', () => zoomBy(0.82));
      graphRoot.querySelector('[data-zoom="out"]')?.addEventListener('click', () => zoomBy(1.22));
      graphRoot.querySelector('[data-zoom="fit"]')?.addEventListener('click', () => { view = { ...initial }; updateView(); });
      graphRoot.querySelector('[data-zoom="reset"]')?.addEventListener('click', () => {
        view = { ...initial };
        updateView();
        projection = 'repos';
        applyProjection(projection);
        if (search) search.value = '';
        if (org) org.value = 'all';
        if (outdated) outdated.setAttribute('aria-pressed', 'false');
        graphRoot.classList.remove('highlight-outdated', 'has-node-selection');
        graphNodes.forEach((node) => node.classList.remove('is-selected-node', 'is-related', 'is-dimmed', 'is-filtered'));
        graphEdges.forEach((edge) => edge.classList.remove('is-path', 'is-dimmed'));
        selectedId = 'record';
        const selected = graphNodes.find((node) => node.dataset.id === selectedId);
        if (selected) showDetails(selected);
      });
      svg.addEventListener('pointerdown', (event) => {
        if ((event.target as Element).closest('[data-graph-node]')) return;
        pointer = { id: event.pointerId, x: event.clientX, y: event.clientY };
        svg.setPointerCapture(event.pointerId);
        svg.classList.add('is-panning');
      });
      svg.addEventListener('pointermove', (event) => {
        if (!pointer || pointer.id !== event.pointerId) return;
        view.x -= (event.clientX - pointer.x) * (view.width / svg.clientWidth);
        view.y -= (event.clientY - pointer.y) * (view.height / svg.clientHeight);
        pointer.x = event.clientX;
        pointer.y = event.clientY;
        updateView();
      });

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — WB" description="This Workbench page does not exist.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">404 · missing worktree</p>
      <h1>This path isn’t in the fleet.</h1>
      <p class="lead">The repository may have moved, or the command was typed from memory.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/">Back to WB</a>
        <a class="btn btn-secondary" href="https://github.com/sneat-dev/wb">Open GitHub ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
